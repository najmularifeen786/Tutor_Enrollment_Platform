# =========================================================
# Tutor Enrollment Platform - .gitignore
# =========================================================

# ---------------------------------------------------------
# Dependencies
# ---------------------------------------------------------
node_modules/
jspm_packages/

# ---------------------------------------------------------
# Environment Variables (Never commit these)
# ---------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------
# Build Output
# ---------------------------------------------------------
dist/
build/
out/
coverage/

# ---------------------------------------------------------
# User Uploaded Files
# ---------------------------------------------------------
backend/uploads/*
!backend/uploads/.gitkeep

# ---------------------------------------------------------
# Logs
# ---------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------------------------------------------------
# Temporary Files
# ---------------------------------------------------------
tmp/
temp/
*.tmp
*.temp

# ---------------------------------------------------------
# Query / Scratch Files
# ---------------------------------------------------------
query.txt

# ---------------------------------------------------------
# IDE Settings
# ---------------------------------------------------------
.vscode/
.idea/

# Visual Studio
*.suo
*.user
*.userosscache
*.sln.docstates
*.ntvs*
*.njsproj
*.sln

# ---------------------------------------------------------
# OS Files
# ---------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ---------------------------------------------------------
# npm Cache
# ---------------------------------------------------------
.npm/

# ---------------------------------------------------------
# TypeScript
# ---------------------------------------------------------
*.tsbuildinfo

# ---------------------------------------------------------
# Vite
# ---------------------------------------------------------
.vite/

# ---------------------------------------------------------
# Miscellaneous
# ---------------------------------------------------------
*.bak
*.swp
*.swo
*.orig